# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=0
DAEMON_NAME=telegram-agent-daemon
POLL_TIMEOUT_SECONDS=25

# ── OpenCode  (/op commands) ──────────────────────────────────────────────────
OPENCODE_BASE_URL=http://localhost:9639
OPENCODE_PROJECT_PATH=/path/to/your/project
OPENCODE_TIMEOUT_MS=600000

# ── Claude Code CLI  (/cc commands) ──────────────────────────────────────────
# Binary name or full path.  Default: claude
# Install:  npm install -g @anthropic-ai/claude-code
CLAUDECODE_BIN=claude
CLAUDECODE_TIMEOUT_MS=600000

# ── Codex CLI  (/cx commands) ─────────────────────────────────────────────────
# Binary name or full path.  Default: codex
# Install:  npm install -g @openai/codex
CODEX_BIN=codex
CODEX_TIMEOUT_MS=600000

# ── Text fallback ────────────────────────────────────────────────────────────
TELEGRAM_FALLBACK_TEXT_ENABLED=true
TELEGRAM_FALLBACK_PRIVATE_ONLY=true

# ── Search (Tavily) ──────────────────────────────────────────────────────────
# Sign up at https://tavily.com — free tier: 1000 searches/month
TAVILY_API_KEY=

# ── X/Twitter (bird) ─────────────────────────────────────────────────────────
# Extract from browser cookies: F12 → Application → Cookies → x.com
BIRD_AUTH_TOKEN=
BIRD_CT0=

# ── Speech-to-Text ───────────────────────────────────────────────────────────
# Groq (primary, fast cloud STT) — sign up at https://console.groq.com
GROQ_API_KEY=
GROQ_STT_MODEL=whisper-large-v3

# Local whisper.cpp (fallback) — optional
WHISPER_BIN=whisper-cli
WHISPER_MODEL_PATH=models/ggml-tiny.bin
WHISPER_LANGUAGE=zh
WHISPER_TIMEOUT_MS=120000
